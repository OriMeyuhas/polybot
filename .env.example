# Polymarket (optional for tracker, needed later for bot)
POLYMARKET_HOST=https://clob.polymarket.com
PRIVATE_KEY=
API_KEY=
API_SECRET=
API_PASSPHRASE=

# Tracker
TRACKED_WALLET=0x63ce342161250d705dc0b16df89036c8e5f9ba9a
POLYGONSCAN_API_KEY=
BINANCE_WS_URL=wss://stream.binance.com:9443/ws

# Settings
LOG_LEVEL=INFO
POLL_INTERVAL_SEC=5

# ===== BOT CONFIG (Phase 1 — Trading Engine) =====
# Strategy thresholds
MIN_SPREAD_EDGE=0.025
MIN_DIRECTIONAL_MOVE=0.002
MAX_PAIR_COST=0.985
MAX_DIRECTIONAL_PRICE=0.93
MIN_DIRECTIONAL_PRICE=0.07
WINDOW_MIN_ELAPSED_SEC=480
POSITION_SIZE_FRACTION=0.10
STOP_LOSS_REVERSAL=0.001

# Risk limits
MAX_CONCURRENT_POSITIONS=8
MAX_DAILY_DRAWDOWN_PCT=0.05
NO_TRADE_FINAL_SEC=60

# Bot polling
BOT_POLL_INTERVAL_MS=500
BALANCE_POLL_SEC=60

# Safety — set to false ONLY when ready for live trading
DRY_RUN=true
DRY_RUN_BANKROLL=1000

# Directional post hard cap — clips outlier losses from FV-gated one-sided ladders (Proposal #53)
DIRECTIONAL_BUDGET_CAP=20.0
